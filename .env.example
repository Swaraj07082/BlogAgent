# Copy to `.env` at this repo root — used by Next.js (via envDir) and FastAPI (via root_env).

# NextAuth — https://next-auth.js.org/configuration/options
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Browser → FastAPI (optional; defaults to http://127.0.0.1:4000)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# Backend / LangChain (add your keys as needed)
# GROQ_API_KEY=
